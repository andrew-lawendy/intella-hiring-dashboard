# Supabase — find these in your project's API settings
# https://supabase.com/dashboard/project/<project-id>/settings/api
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Supabase service role key — used only by seed scripts (never expose to the browser)
# Keep this out of version control; add to .env.local only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
